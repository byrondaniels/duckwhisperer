.DS_Store

# Build output
.build/
build/
dist/
release/

# Local Python runtimes
.venv/
.translation-venv/
__pycache__/
*.pyc

# Downloaded Whisper backend and source archives
vendor/
*.zip
*.dmg

# Runtime model and translation data must not be committed.
Resources/Models/*.bin
Resources/Translation/Data/
Resources/Translation/Cache/
Resources/Translation/Packages/
Resources/Translation/*.argosmodel

# Local logs and scratch files
*.log

# Local Sparkle release configuration
.sparkle-public-ed-key
.sparkle-private-ed-key
